# =============================================================================
# NCU TOM Environment Configuration
# Copy to .env.local and fill in your values: cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=tom
POSTGRES_USER=tom
POSTGRES_PASSWORD=change_this_password

# -----------------------------------------------------------------------------
# Django Backend
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=generate-a-random-secret-key
DJANGO_STAGE=local
DEBUG=true
ALLOWED_HOSTS=127.0.0.1,localhost,django

DOMAIN=localhost:3000
SITE_NAME="NCU TOM"

# Database connection (must match PostgreSQL settings above)
ENGINE=django.db.backends.postgresql
DATABASE=tom
DB_USER=tom
DB_PASSWORD=change_this_password
DB_HOST=db
DB_PORT=5432

# JWT tokens
SIGNING_KEY=generate-a-random-signing-key
VERIFYING_KEY=generate-a-random-signing-key
ALGORITHM=HS512

# Auth cookies
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# CORS (frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://nextjs:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://nextjs:3000

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SERVER_API_HOST=http://django:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_HOME_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
AUTH_SECRET=generate-a-32-character-secret

# -----------------------------------------------------------------------------
# OAuth Providers (optional - leave empty to disable)
# -----------------------------------------------------------------------------
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# -----------------------------------------------------------------------------
# Email (optional - for notifications)
# -----------------------------------------------------------------------------
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# -----------------------------------------------------------------------------
# Local Superuser (Docker auto-creates this user)
# -----------------------------------------------------------------------------
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_USERNAME=Admin
DJANGO_SUPERUSER_PASSWORD=change_this_password
DJANGO_SUPERUSER_FIRST_NAME=Admin
DJANGO_SUPERUSER_LAST_NAME=User
DJANGO_SUPERUSER_ROLE=1
DJANGO_SUPERUSER_INSTITUTE=NCU
DJANGO_SUPERUSER_USE_DEMO_TARGETS=True
